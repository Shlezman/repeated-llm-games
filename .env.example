# Copy to .env (gitignored) and fill in. NEVER commit real keys.

# --- Provider API keys (set only those you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LiteLLM reads provider-native keys from the environment too (OpenRouter, Azure, etc.)
# OPENROUTER_API_KEY=

# --- Models under test (the inputs; no model name is hardcoded in code) ---
# Referenced from config YAML as ${LLMGAMES_MODEL_A} / ${LLMGAMES_MODEL_B}.
LLMGAMES_MODEL_A=
LLMGAMES_MODEL_B=

# --- Postgres response cache ---
# Used by the default cache backend. TLS requested via PGSSLMODE (default: require).
DATABASE_URL=
PGSSLMODE=require
