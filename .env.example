# Copy to .env (gitignored) and fill in. NEVER commit real keys.

# --- Provider API keys (set only those you use) ---
# LangChain reads these from the environment.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Models under test (the inputs; no model name is hardcoded in code) ---
# Referenced from config YAML as ${LLMGAMES_MODEL_A} / ${LLMGAMES_MODEL_B}.
# Provider: openai | anthropic | ... ; leave empty to infer from the model id.
LLMGAMES_PROVIDER_A=
LLMGAMES_MODEL_A=
LLMGAMES_PROVIDER_B=
LLMGAMES_MODEL_B=

# --- Internal LLM gateway (OpenAI-compatible), e.g. staging llm-gw ---
# The gateway key goes in OPENAI_API_KEY above.
LLM_GW_BASE_URL=        # e.g. https://<stg-llm-gw-host>/v1

# Single-model run (config/runs/llm_gw_stg.yaml):
LLM_GW_MODEL=           # one model id the gateway serves

# Multi-model run — 6 models play each other (config/runs/llm_gw_multi.yaml, used by
# docker compose): 2 per provider (heavy + light). Ids below are from the stg gw
# allowlist (config-stg-eu-west-1.json). Verify with: curl "$LLM_GW_BASE_URL/models".
LLM_GW_MODEL_1=gpt-4.1                    # OpenAI heavy
LLM_GW_MODEL_2=gpt-4.1-mini              # OpenAI light
LLM_GW_MODEL_3=gemini-3.1-pro-preview    # Gemini heavy
LLM_GW_MODEL_4=gemini-3.1-flash-lite     # Gemini light
LLM_GW_MODEL_5=claude-opus-4-6           # Anthropic heavy
LLM_GW_MODEL_6=claude-haiku-4-5          # Anthropic light

# --- Postgres LLM cache ---
# For docker compose: leave these as-is (compose wires DATABASE_URL to the db
# service automatically). Optionally override the DB credentials:
POSTGRES_USER=llmgames
POSTGRES_PASSWORD=llmgames
POSTGRES_DB=llmgames
# For a non-docker run against your own Postgres, set DATABASE_URL directly, e.g.
# postgresql+psycopg://user:pass@host:5432/db   (TLS via PGSSLMODE, default require)
DATABASE_URL=
PGSSLMODE=require
